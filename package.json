{
  "name": "lp-project",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "engines": {
    "node": "20.x"
  },
  "scripts": {
    "dev": "next dev",
    "dev:webpack": "next dev --webpack",
    "build": "next build",
    "build:webpack": "next build --webpack",
    "start": "next start",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "analyze": "cross-env ANALYZE=true next build",
    "assets:encode": "node scripts/encode-public-assets.cjs",
    "preview:kinetic-blok45-html": "node scripts/build-kinetic-blok45-react-preview-html.mjs",
    "test:e2e": "playwright test",
    "test:e2e:install": "playwright install --with-deps chromium"
  },
  "dependencies": {
    "@gsap/react": "2.1.1",
    "@owocni/cennik-form": "workspace:*",
    "gsap": "3.12.7",
    "imagesloaded": "^5.0.0",
    "lenis": "1.1.18",
    "lottie-web": "5.12.2",
    "next": "16.1.6",
    "react": "19.0.0",
    "react-dom": "19.0.0",
    "server-only": "0.0.1",
    "three": "^0.183.2"
  },
  "devDependencies": {
    "@argos-ci/playwright": "^6.6.2",
    "@eslint/eslintrc": "3.2.0",
    "@next/bundle-analyzer": "16.1.6",
    "@playwright/test": "^1.59.1",
    "@types/imagesloaded": "^4.1.7",
    "@types/node": "20.17.19",
    "@types/react": "19.0.10",
    "@types/react-dom": "19.0.4",
    "@types/three": "^0.183.1",
    "autoprefixer": "10.4.20",
    "babel-plugin-react-compiler": "^1.0.0",
    "cross-env": "7.0.3",
    "esbuild": "^0.25.5",
    "eslint": "9.20.1",
    "eslint-config-next": "16.1.6",
    "postcss": "8.5.3",
    "tailwindcss": "3.4.17",
    "typescript": "5.7.3"
  }
}
