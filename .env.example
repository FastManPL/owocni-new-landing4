# Opcjonalnie: inny adres zapisu niż domyślny /api/cennik (ten sam serwer).
# NEXT_PUBLIC_FORM_SUBMIT_URL=/api/cennik

# Marker.io — tylko przy ?marker=1: snippet (markerConfig + shim z edge.marker.io). Wartość `project` jak w panelu instalacji.
# NEXT_PUBLIC_MARKER_PROJECT_ID=

# --- Google Tag Manager (Konstytucja I7 + G7 + I1) ---
# Włącz jedną z opcji:
# • Standard: sam identyfikator kontenera → ładuje gtm.js z www.googletagmanager.com
# NEXT_PUBLIC_GTM_CONTAINER_ID=GTM-XXXXXXX
# • sGTM / własny host: pełny URL do gtm.js (dns-prefetch bierze origin z tego URL)
# NEXT_PUBLIC_GTM_SCRIPT_URL=https://twoj-sgtm.example/gtm.js?id=GTM-XXXXXXX
# Opcjonalnie: origin iframe <noscript> (domyślnie https://www.googletagmanager.com)
# NEXT_PUBLIC_GTM_NOSCRIPT_ORIGIN=https://www.googletagmanager.com
